# PostgreSQL (Railway Postgres → Variables → DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/stankomplekt"

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""   # довільний рядок, до 256 символів [A-Za-z0-9_-]

# NextAuth
NEXTAUTH_SECRET=""           # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Базовий URL застосунку (для webhook та посилань у повідомленнях)
APP_BASE_URL="http://localhost:3000"

# Cron (щоденний дайджест о 08:00 Києва)
CRON_SECRET=""

