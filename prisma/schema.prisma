// ТОВ «СТАН КОМПЛЕКТ» — сервісна служба
// Схема даних. Часовий пояс застосунку: Europe/Kyiv.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN // керівник відділу
  BRIGADE_LEADER // бригадир
  VIEWER // директор (тільки перегляд)
  ACCOUNTANT // бухгалтер (перегляд, контроль наказів на відрядження)
}

enum Locale {
  UK
  RU
}

enum TaskStatus {
  ASSIGNED // Призначено
  CONFIRMED // Підтверджено бригадиром
  EN_ROUTE // В дорозі
  ON_SITE // На об'єкті
  DONE // Виконано
  NOT_DONE // Не виконано (з причиною)
}

enum TaskType {
  ENGINEERING // інжиніринг
  PNR // пусконалагоджувальні роботи
  REPAIR // ремонт
  DEFECTATION // дефектовка
  VISIT // виїзд
  OTHER // інше
}

enum ExecutorType {
  BRIGADE // виконує бригада
  OUTSOURCE // виконує зовнішній підрядник
}

enum LogSource {
  WEB
  TELEGRAM
  SYSTEM
}

model User {
  id             String    @id @default(cuid())
  name           String
  login          String    @unique
  passwordHash   String
  role           Role
  locale         Locale    @default(UK)
  brigadeId      String?
  brigade        Brigade?  @relation(fields: [brigadeId], references: [id])
  telegramChatId String?   @unique
  tgLinkCode     String?   @unique
  tgLinkExpires  DateTime?
  isActive       Boolean   @default(true)

  createdTasks Task[]          @relation("CreatedBy")
  statusLogs   TaskStatusLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brigade {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  users          User[]
  tasks          Task[] @relation("TaskPrimaryBrigade")
  secondaryTasks Task[] @relation("TaskSecondBrigade")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id       String  @id @default(cuid())
  name     String
  edrpou    String? // код ЄДРПОУ
  city      String
  oblast    String
  managerId String? // закріплений менеджер
  manager   Manager? @relation(fields: [managerId], references: [id])
  note      String?

  contacts ClientContact[]
  invoices Invoice[]
  machines Machine[]
  tasks    Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// Менеджери, за якими закріплені клієнти (розширюваний довідник)
model Manager {
  id   String @id @default(cuid())
  name String @unique

  clients Client[]

  createdAt DateTime @default(now())
}

// Контактні особи клієнта
model ClientContact {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  position String? // посада
  fullName String // ПІБ
  phone    String? // телефон

  createdAt DateTime @default(now())

  @@index([clientId])
}

// Рахунки клієнта (до одного клієнта — багато рахунків)
model Invoice {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  number   String
  note     String?

  tasks Task[]

  createdAt DateTime @default(now())

  @@unique([clientId, number])
}

// Довідник типів обладнання (розширюваний без міграцій коду)
model MachineType {
  id     String @id @default(cuid())
  nameUk String @unique
  nameRu String

  machines Machine[]
}

model Machine {
  id           String      @id @default(cuid())
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id])
  typeId       String
  type         MachineType @relation(fields: [typeId], references: [id])
  model        String
  serialNumber String?
  note         String?

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Task {
  id              String       @id @default(cuid())
  taskType        TaskType     @default(OTHER)
  executorType    ExecutorType @default(BRIGADE)
  brigadeId       String? // основна бригада (обов'язково при executorType=BRIGADE)
  brigade         Brigade?     @relation("TaskPrimaryBrigade", fields: [brigadeId], references: [id])
  secondBrigadeId String? // друга бригада на об'єкті (опційно)
  secondBrigade   Brigade?     @relation("TaskSecondBrigade", fields: [secondBrigadeId], references: [id])
  outsourceName   String? // обов'язково при executorType=OUTSOURCE
  clientId      String
  client        Client     @relation(fields: [clientId], references: [id])
  machines      Machine[] // верстати, за якими їде бригада (може бути кілька)
  city          String
  oblast        String
  invoiceId     String?
  invoice       Invoice?   @relation(fields: [invoiceId], references: [id])
  orderNumber   String? // № наказу про відрядження
  note          String?
  dateFrom      DateTime   @db.Date
  dateTo        DateTime   @db.Date
  status        TaskStatus @default(ASSIGNED)
  failureReason String? // обов'язкова при NOT_DONE
  createdById   String
  createdBy     User       @relation("CreatedBy", fields: [createdById], references: [id])

  statusLogs TaskStatusLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brigadeId, dateFrom, dateTo])
  @@index([status])
  @@index([invoiceId])
  @@index([secondBrigadeId])
}

model TaskStatusLog {
  id         String      @id @default(cuid())
  taskId     String
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  fromStatus TaskStatus?
  toStatus   TaskStatus
  comment    String?
  source     LogSource
  createdAt  DateTime    @default(now())

  @@index([taskId, createdAt])
}

model GeoCache {
  id     String @id @default(cuid())
  city   String
  oblast String
  lat    Float
  lng    Float

  createdAt DateTime @default(now())

  @@unique([city, oblast])
}
