// ТОВ «СТАН КОМПЛЕКТ» — сервісна служба
// Схема даних. Часовий пояс застосунку: Europe/Kyiv.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN // керівник відділу
  BRIGADE_LEADER // бригадир
  BRIGADE_MEMBER // працівник бригади (перегляд своїх задач, без зміни статусів)
  STOREKEEPER // комірник (доступ лише до розділу «Інструмент»)
  VIEWER // директор (тільки перегляд)
  ACCOUNTANT // бухгалтер (перегляд, контроль наказів на відрядження)
}

enum Locale {
  UK
  RU
}

enum TaskStatus {
  ASSIGNED // Призначено
  CONFIRMED // Підтверджено бригадиром
  EN_ROUTE // В дорозі
  ON_SITE // На об'єкті
  DONE // Виконано
  PARTIALLY_DONE // Виконано не повністю (з коментарем)
  NOT_DONE // Не виконано (з причиною)
}

enum TaskType {
  ENGINEERING // інжиніринг
  PNR // пусконалагоджувальні роботи
  REPAIR // ремонт
  DEFECTATION // дефектовка
  VISIT // виїзд
  OTHER // інше
}

enum ExecutorType {
  BRIGADE // виконує бригада
  OUTSOURCE // виконує зовнішній підрядник
}

enum CommentKind {
  QUESTION // питання бригадира
  ANSWER // відповідь керівника
  COMMENT // коментар із веб-інтерфейсу
}

enum RequestStatus {
  NEW // нова заявка
  CLOSED // опрацьована (створено задачу або закрита вручну)
}

enum LogSource {
  WEB
  TELEGRAM
  SYSTEM
}

model User {
  id             String    @id @default(cuid())
  name           String
  login          String    @unique
  passwordHash   String
  role           Role
  locale         Locale    @default(UK)
  brigadeId      String?
  brigade        Brigade?  @relation(fields: [brigadeId], references: [id])
  telegramChatId String?   @unique
  tgLinkCode     String?   @unique
  tgLinkExpires  DateTime?
  tgPendingAction String? // JSON: очікувана відповідь у боті (причина, текст питання)
  isActive       Boolean   @default(true)

  createdTasks  Task[]          @relation("CreatedBy")
  assignedTasks Task[]          @relation("TaskAssignees")
  statusLogs    TaskStatusLog[]
  taskComments    TaskComment[]
  attachmentsMade TaskAttachment[]
  toolAllocations ToolAllocation[]
  toolMovements   ToolMovement[]
  toolRequests    ToolRequest[]   @relation("ToolRequestedBy")
  pushSubs        PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brigade {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  users            User[]
  tasks            Task[] @relation("TaskPrimaryBrigade")
  secondaryTasks   Task[] @relation("TaskSecondBrigade")
  toolAllocations  ToolAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id       String  @id @default(cuid())
  name     String
  edrpou    String? // код ЄДРПОУ
  city      String
  oblast    String
  managerId String? // закріплений менеджер
  manager   Manager? @relation(fields: [managerId], references: [id])
  note      String?

  contacts        ClientContact[]
  invoices        Invoice[]
  machines        Machine[]
  tasks           Task[]
  serviceRequests ServiceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// Менеджери, за якими закріплені клієнти (розширюваний довідник)
model Manager {
  id   String @id @default(cuid())
  name String @unique

  clients        Client[]
  launchRequests LaunchRequest[]

  createdAt DateTime @default(now())
}

// Контактні особи клієнта
model ClientContact {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  position String? // посада
  fullName String // ПІБ
  phone    String? // телефон

  createdAt DateTime @default(now())

  @@index([clientId])
}

// Рахунки клієнта (до одного клієнта — багато рахунків)
model Invoice {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  number   String
  note     String?

  tasks Task[]

  createdAt DateTime @default(now())

  @@unique([clientId, number])
}

// Довідник типів обладнання (розширюваний без міграцій коду)
model MachineType {
  id     String @id @default(cuid())
  nameUk String @unique
  nameRu String

  machines Machine[]
}

model Machine {
  id           String      @id @default(cuid())
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id])
  typeId       String
  type         MachineType @relation(fields: [typeId], references: [id])
  model           String
  serialNumber    String?
  warrantyMonths  Int     @default(12) // гарантійний строк, міс. (12/18/24/36)
  note            String?

  tasks           Task[]
  serviceRequests ServiceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Task {
  id              String       @id @default(cuid())
  taskType        TaskType     @default(OTHER)
  executorType    ExecutorType @default(BRIGADE)
  brigadeId       String? // основна бригада (обов'язково при executorType=BRIGADE)
  brigade         Brigade?     @relation("TaskPrimaryBrigade", fields: [brigadeId], references: [id])
  secondBrigadeId String? // друга бригада на об'єкті (опційно)
  secondBrigade   Brigade?     @relation("TaskSecondBrigade", fields: [secondBrigadeId], references: [id])
  outsourceName   String? // обов'язково при executorType=OUTSOURCE
  assignees       User[]       @relation("TaskAssignees") // конкретні виконавці (бригадири + працівники)
  clientId      String
  client        Client     @relation(fields: [clientId], references: [id])
  machines      Machine[] // верстати, за якими їде бригада (може бути кілька)
  city          String
  oblast        String
  address       String? // вулиця/об'єкт (необов'язково)
  lat           Float? // точка на карті, якщо вказана вручну
  lng           Float?
  invoiceId     String?
  invoice       Invoice?   @relation(fields: [invoiceId], references: [id])
  orderNumber   String? // № наказу про відрядження
  note          String?
  dateFrom      DateTime   @db.Date
  dateTo        DateTime   @db.Date
  status        TaskStatus @default(ASSIGNED)
  failureReason String? // обов'язкова при NOT_DONE
  createdById   String
  createdBy     User       @relation("CreatedBy", fields: [createdById], references: [id])

  statusLogs TaskStatusLog[]
  comments    TaskComment[]
  attachments TaskAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brigadeId, dateFrom, dateTo])
  @@index([status])
  @@index([invoiceId])
  @@index([secondBrigadeId])
}

// Обговорення задачі (питання бригадира ↔ відповіді керівника, коментарі)
model TaskComment {
  id        String      @id @default(cuid())
  taskId    String
  task      Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  kind      CommentKind
  text      String
  createdAt DateTime    @default(now())

  @@index([taskId, createdAt])
}

model TaskStatusLog {
  id         String      @id @default(cuid())
  taskId     String
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  fromStatus TaskStatus?
  toStatus   TaskStatus
  comment    String?
  source     LogSource
  createdAt  DateTime    @default(now())

  @@index([taskId, createdAt])
}

// Заявки на виїзд сервісної служби (з Telegram-бота, від неавторизованих)
model ServiceRequest {
  id           String        @id @default(cuid())
  number       Int           @unique @default(autoincrement()) // людський номер заявки
  status       RequestStatus @default(NEW)
  chatId       String? // Telegram chat заявника (для зворотного зв'язку)
  serialNumber String
  machineId    String?
  machine      Machine?      @relation(fields: [machineId], references: [id])
  clientId     String?
  client       Client?       @relation(fields: [clientId], references: [id])
  // якщо верстат не знайдено за S/N:
  machineTypeText String?
  modelText       String?
  contactName     String?
  contactPhone    String?
  problem      String
  taskId       String? // створена з заявки задача
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, createdAt])
}

// Стан діалогу бота (для покрокових сценаріїв, зокрема заявок)
model BotDialog {
  chatId    String   @id
  state     String // JSON
  updatedAt DateTime @updatedAt
}

enum ToolClass {
  HAND // ручний
  ELECTRIC // електричний
  MEASURING // вимірювальний
  TOOLING // оснастка
  MODULES // модулі
  ZIP // ЗІП
  CONSUMABLES // витратні матеріали
  OTHER // інше
}

enum ToolStatus {
  WORKING // робочий
  NEEDS_REPAIR // потребує ремонту
  BROKEN // зламаний
  LOST // втрачений
}

enum ToolHolderKind {
  WAREHOUSE
  BRIGADE
  PERSON
}

enum ToolReqKind {
  PURCHASE // заявка на закупку
  ISSUE // заявка на видачу зі складу
}

enum ToolReqStatus {
  NEW // нова
  APPROVED // погоджена керівником (видача — чекає на комірника)
  DONE
  REJECTED
}

// Робочий інструмент — позиція (може бути розподілена по кількох місцях за кількістю)
model Tool {
  id              String     @id @default(cuid())
  name            String
  manufacturer    String?
  inventoryNumber String?
  toolClass       ToolClass
  status          ToolStatus @default(WORKING)
  quantity        Int        @default(1) // загальна кількість одиниць цієї позиції
  note            String?

  allocations ToolAllocation[]
  movements   ToolMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Розподіл кількості інструменту по місцях: склад / бригада / людина.
// Сума allocations.quantity по одному Tool завжди дорівнює Tool.quantity.
model ToolAllocation {
  id         String         @id @default(cuid())
  toolId     String
  tool       Tool           @relation(fields: [toolId], references: [id], onDelete: Cascade)
  holderKind ToolHolderKind
  brigadeId  String?
  brigade    Brigade?       @relation(fields: [brigadeId], references: [id])
  userId     String?
  user       User?          @relation(fields: [userId], references: [id])
  quantity   Int            @default(0)

  updatedAt DateTime @updatedAt

  @@unique([toolId, holderKind, brigadeId, userId])
  @@index([brigadeId])
  @@index([userId])
}

// Журнал переміщень і змін інструменту
model ToolMovement {
  id       String  @id @default(cuid())
  toolId   String
  tool     Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)
  byUserId String?
  byUser   User?   @relation(fields: [byUserId], references: [id])
  text     String

  createdAt DateTime @default(now())

  @@index([toolId, createdAt])
}

// Заявки бригадирів: закупка / видача інструменту
model ToolRequest {
  id            String        @id @default(cuid())
  kind          ToolReqKind
  status        ToolReqStatus @default(NEW)
  text          String
  requestedById String?
  requestedBy   User?         @relation("ToolRequestedBy", fields: [requestedById], references: [id])
  resolvedById  String?
  resolvedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([kind, status, createdAt])
}

// Фото/відео вкладення до задачі (звіти при зміні статусу), файли на Railway Volume
model TaskAttachment {
  id       String  @id @default(cuid())
  taskId   String
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName String // оригінальна назва
  filePath String  @unique // відносний шлях на диску
  mimeType String
  size     Int
  byUserId String?
  byUser   User?   @relation(fields: [byUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

// Заявка на запуск верстата (публічна форма для менеджерів)
model LaunchRequest {
  id          String        @id @default(cuid())
  number      Int           @unique @default(autoincrement())
  status      RequestStatus @default(NEW)
  managerId   String?
  manager     Manager?      @relation(fields: [managerId], references: [id], onDelete: SetNull)
  clientName  String
  contactInfo String?
  city        String?
  machineText String
  desiredDate DateTime?     @db.Date
  note        String?
  taskId      String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

// Web Push підписки (PWA-нотифікації)
model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())

  @@index([userId])
}

model GeoCache {
  id     String @id @default(cuid())
  city   String
  oblast String
  lat    Float
  lng    Float

  createdAt DateTime @default(now())

  @@unique([city, oblast])
}
